	month = jan,
	year = {2015},
	keywords = {Amyloid imaging, Centiloid scale, Pittsburgh compound B, Positron emission tomography, Standardize},
	pages = {1--15.e4},
	file = {Full Text PDF:files/2864/Klunk et al. - 2015 - The Centiloid Project Standardizing quantitative amyloid plaque estimation by PET.pdf:application/pdf;ScienceDirect Snapshot:files/2863/S155252601402500X.html:text/html},
